root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.py]
indent_size = 4

[Makefile]
indent_style = tab

# CephasOps Tenant Safety Analyzer Rules
# --------------------------------------
# CEPHAS001: Unsafe IgnoreQueryFilters on tenant-scoped entity
# CEPHAS002: IgnoreQueryFilters with ambiguous tenant scoping
# CEPHAS003: Possible EF Core relationship fixup navigation mutation risk
# CEPHAS004: Tenant-scoped entity queried by Id only without explicit company scoping
#
# Current policy:
# - all rules are warnings in v1
# - CEPHAS001 is the likely future candidate for promotion to error
# - CEPHAS002 and CEPHAS003 remain warnings because they are more heuristic

[*.cs]
dotnet_diagnostic.CEPHAS001.severity = warning
dotnet_diagnostic.CEPHAS002.severity = warning
dotnet_diagnostic.CEPHAS003.severity = warning
dotnet_diagnostic.CEPHAS004.severity = warning
