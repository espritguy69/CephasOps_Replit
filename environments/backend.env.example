# Backend environment example

ASPNETCORE_ENVIRONMENT=Development
# Supabase PostgreSQL connection
ConnectionStrings__DefaultConnection=Host=db.jgahsbfoydwdgipcjvxe.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SslMode=Require;Trust Server Certificate=true;

# JWT Configuration
