# ============================================================
# CephasOps Production Environment Variables
# Copy to .env and fill in all values before deployment
# ============================================================

# --- PostgreSQL ---
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=cephasops;Username=cephasops_app;Password=CHANGE_ME_strong_password_here;SslMode=Disable

# --- JWT Authentication ---
Jwt__Key=CHANGE_ME_minimum_32_character_secret_key_here_!!
Jwt__Issuer=CephasOps
Jwt__Audience=CephasOps

# --- Encryption ---
Encryption__Key=CHANGE_ME_exactly_32_characters!!
Encryption__IV=CHANGE_ME_16chars

# --- CORS (your Replit frontend URL or custom domain) ---
Cors__AllowedOrigins__0=https://your-app.replit.app

# --- Tenant ---
Tenant__DefaultCompanyId=00000000-0000-0000-0000-000000000001

# --- Syncfusion (backend Excel/PDF processing, optional) ---
# SYNCFUSION_LICENSE_KEY=

# --- Redis (optional, omit for in-memory rate limiting) ---
# ConnectionStrings__Redis=redis:6379

# --- Carbone Document Generation (optional) ---
# Carbone__ApiKey=
# Carbone__BaseUrl=https://api.carbone.io

# --- WhatsApp Cloud API (optional) ---
# WhatsAppCloudApi__AccessToken=
# WhatsAppCloudApi__PhoneNumberId=
# WhatsAppCloudApi__BusinessAccountId=

# --- SMTP Email (optional) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SSL=true
