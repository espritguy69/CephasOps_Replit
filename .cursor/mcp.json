{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"],
      "cwd": "${workspaceFolder}/frontend"
    },
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem"],
      "cwd": "${workspaceFolder}"
    },
    "rg-search": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-ripgrep"],
      "cwd": "${workspaceFolder}"
    }
  }
}
